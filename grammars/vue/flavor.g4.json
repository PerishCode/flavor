{
  "bundle": "vue",
  "grammars": [
    {
      "directives": {
        "entry": "sfc_document",
        "owner": "crates/flavor-plugin-vue"
      },
      "id": "vue-sfc",
      "sections": {
        "diagnostics": {
          "duplicate.script": "more than one script_block -> vue/parse/error",
          "duplicate.setup": "more than one script_setup_block -> vue/parse/error",
          "missing.close": "block missing end_tag -> vue/parse/error",
          "unsupported.setup_src": "script setup with src -> vue/parse/error"
        },
        "facts": {
          "descriptor.script": "first script_block without setup -> VueSfcDescriptor.script: VueSfcBlock(content, start_offset, start_line) -> Fact(payload.content, payload.start_offset, payload.start_line)",
          "descriptor.script_setup": "first script_block with setup -> VueSfcDescriptor.script_setup: VueSfcBlock(content, start_offset, start_line) -> Fact(payload.content, payload.start_offset, payload.start_line)",
          "descriptor.styles": "style_block* -> VueSfcDescriptor.styles",
          "descriptor.template": "first template_block -> VueSfcDescriptor.template",
          "script.embedded": "script content with lang js ts jsx tsx -> embedded script scope(content, start_line, lang) -> Fact(payload.content, payload.lang, payload.tsx, payload.start_offset, payload.start_line)"
        },
        "nodes": {
          "attribute": "descriptor:attribute",
          "custom_block": "descriptor:custom",
          "script_block": "descriptor:script",
          "script_setup_block": "descriptor:script_setup",
          "sfc_document": "descriptor:VueSfcDescriptor",
          "style_block": "descriptor:style",
          "template_block": "descriptor:template"
        },
        "productions": {
          "attribute": "attribute_name attribute_value?",
          "block": "template_block | script_block | script_setup_block | style_block | custom_block",
          "script_block": "start_tag script_content end_tag",
          "script_setup_block": "start_tag setup_attribute script_content end_tag",
          "sfc_document": "block* eof",
          "style_block": "start_tag style_content end_tag",
          "template_block": "start_tag template_content end_tag"
        },
        "recovery": {
          "descriptor.blocks": "preserve well-formed blocks around malformed blocks",
          "embedded.skip": "skip script languages outside js ts jsx tsx",
          "missing.close": "consume until eof for current block"
        },
        "spans": {
          "block.content": "source byte range inside start and end tags",
          "block.line": "start tag line",
          "diagnostic.range": "offending block or attribute range",
          "embedded.offset": "block content start line and byte offset"
        },
        "tokens": {
          "attribute_name": "scanner:attribute_name",
          "attribute_value": "scanner:attribute_value",
          "end_tag_open": "literal:</",
          "eof": "synthetic:EOF",
          "raw_text": "scanner:block_content",
          "tag_close": "literal:>",
          "tag_open": "literal:<"
        }
      },
      "sources": {
        "lexer": "VueSfcLexer.g4",
        "parser": "VueSfcParser.g4"
      }
    },
    {
      "directives": {
        "entry": "template_document",
        "owner": "crates/flavor-plugin-vue"
      },
      "id": "vue-template",
      "sections": {
        "diagnostics": {
          "expression.error": "TypeScript expression diagnostic -> vue/parse/error",
          "missing.end_tag": "unclosed element -> vue/parse/error",
          "missing.interpolation": "unclosed interpolation -> vue/parse/error"
        },
        "facts": {
          "directive.class": "directive_name prefix -> bind event slot model control custom",
          "embedded.expression": "expression_text -> TypeScript expression validation",
          "template.directive": "directive -> VueFacts.template_directive_count + VueFacts.template_directives: VueTemplateDirectiveFact(name, class, span, line)",
          "template.element": "start_tag -> VueFacts.template_element_count + VueFacts.template_elements: VueTemplateElementFact(name, span, line)",
          "template.expression": "interpolation | directive_expression | dynamic_argument -> VueFacts.template_expression_count + VueFacts.template_expressions: VueTemplateExpressionFact(span, line)"
        },
        "nodes": {
          "attribute": "VueTemplateKind::Attribute",
          "directive": "VueTemplateKind::Directive",
          "directive_expression": "VueTemplateKind::DirectiveExpression",
          "element": "VueTemplateKind::Element",
          "end_tag": "VueTemplateKind::EndTag",
          "interpolation": "VueTemplateKind::Interpolation",
          "start_tag": "VueTemplateKind::StartTag",
          "template_document": "TemplateAst.root"
        },
        "productions": {
          "child": "text | element | interpolation",
          "directive": "directive_name directive_argument? directive_modifier* directive_expression?",
          "directive_expression": "attribute_value | expression_text",
          "element": "start_tag child* end_tag?",
          "interpolation": "mustache_open expression_text mustache_close",
          "start_tag": "tag_open tag_name attribute_or_directive* tag_close",
          "template_document": "child* eof"
        },
        "recovery": {
          "missing.end_tag": "close at parent boundary",
          "missing.interpolation": "close at next tag or eof",
          "v_pre": "keep raw text and skip expression validation"
        },
        "spans": {
          "diagnostic.range": "host mapped range",
          "host.range": "template block start offset + node range",
          "line": "host line index position",
          "node.range": "template byte range"
        },
        "tokens": {
          "attribute_name": "scanner:attribute_name",
          "attribute_value": "scanner:attribute_value",
          "directive_name": "scanner:directive_name",
          "end_tag_open": "literal:</",
          "eof": "synthetic:EOF",
          "mustache_close": "literal:}}",
          "mustache_open": "literal:{{",
          "tag_close": "literal:>",
          "tag_open": "literal:<",
          "text": "scanner:text"
        }
      },
      "sources": {
        "lexer": "VueTemplateLexer.g4",
        "parser": "VueTemplateParser.g4"
      }
    }
  ]
}
